# ─────────────────────────────────────────────────────────────
# Casa Bevk — environment variables
# Copy to `.env.local` and fill in. `.env.local` is gitignored.
# ─────────────────────────────────────────────────────────────

# Supabase — Project Settings → API (or Settings → API Keys)
# Project ref (dashboard URL): bqahklmyziowboicwwjj for casa-bevk
# URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Public anon / publishable key (safe to expose to the browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Server-only secret — NEVER expose to the client or commit a real value.
# Used by admin scripts (e.g. provisioning the two household users, seeding).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Public base URL of the app (used for auth redirects / email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
